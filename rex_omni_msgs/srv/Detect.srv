# Object detection, referring expression grounding, or GUI grounding.
uint8 VARIANT_DETECTION=0
uint8 VARIANT_GUI_GROUNDING=1

sensor_msgs/Image image  # raw input image; leave empty when using compressed_image
sensor_msgs/CompressedImage compressed_image  # alternative jpeg/png input, used when image is empty
string[] categories  # category names or referring expressions
uint8 variant
---
std_msgs/Header header  # copied from the request image (stamp, frame_id)
bool success
string message          # error description when success is false
float32 inference_time  # seconds spent in model inference
Detection[] detections
